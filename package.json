{
  "name": "deusbox",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "DeusBox — A god simulator where you shape worlds, spawn creatures, and command the forces of nature.",
  "author": "Tâm Doãn Bắc",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "vite build --mode production && npx vite-bundle-visualizer",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "dependencies": {
    "phaser": "3.90.0",
    "bitecs": "0.4.0",
    "simplex-noise": "4.0.3"
  },
  "devDependencies": {
    "typescript": "^5.5",
    "vite": "^6",
    "vite-plugin-compression2": "^1.3.3",
    "@rollup/plugin-terser": "^0.4.4",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
